<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="72" height="72" viewBox="0 0 72 72">
  <!-- Fond principal -->
  <rect width="72" height="72" rx="13" fill="#3D2B1F"/>

  <!-- Motif décoratif — vague stylisée Sénégal -->
  <circle cx="36" cy="27" r="16" fill="none" stroke="#C4682B" stroke-width="3"/>
  <circle cx="36" cy="27" r="9" fill="#C4682B" opacity="0.3"/>

  <!-- Étoile centrale (inspirée drapeau Sénégal) -->
  <text x="36" y="31" text-anchor="middle" font-size="14" fill="#C49F4A">★</text>

  <!-- Texte NIO FAR -->
  <text x="36" y="37" text-anchor="middle"
        font-family="Georgia, 'Times New Roman', serif"
        font-size="16" font-weight="bold" fill="#FFFFFF" letter-spacing="1">NIO FAR</text>

  <!-- Sous-titre -->
  <text x="36" y="50" text-anchor="middle"
        font-family="Georgia, serif"
        font-size="8" fill="#C4682B" letter-spacing="2">TOURISME</text>
</svg>